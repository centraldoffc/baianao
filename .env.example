# =====================================================================
# Supabase — pegue em: Project Settings → Database → Connection string
# =====================================================================

# Usada em produção (Vercel/serverless) — porta 6543, modo pooling
DATABASE_URL="postgresql://postgres.[ref]:[senha]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Usada para migrations (prisma db push / prisma migrate) — porta 5432, conexão direta
DIRECT_URL="postgresql://postgres.[ref]:[senha]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Supabase — chaves públicas (pode ir para o código)
NEXT_PUBLIC_SUPABASE_URL="https://fblqecsuzxdearcctpwx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_9IhtSbrjwHq1v7X8agSGPg_MlJZmScI"

# Supabase — Service Role Key (NUNCA exponha no frontend nem comite no GitHub)
# Encontre em: Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key-aqui"

# =====================================================================
# NextAuth
# =====================================================================
NEXTAUTH_SECRET="gere com: openssl rand -base64 32"

# Em desenvolvimento:
NEXTAUTH_URL="http://localhost:3000"
# Em produção (Vercel): coloque a URL final do seu site, ex:
# NEXTAUTH_URL="https://baianao.vercel.app"
